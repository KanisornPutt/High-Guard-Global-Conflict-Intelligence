# Base API Gateway for countries/events endpoints
VITE_API_BASE=https://your-api-gateway-id.execute-api.ap-southeast-1.amazonaws.com/prod

# Direct countrySummarization Lambda Function URL (POST)
VITE_COUNTRY_NEWS_LAMBDA_URL=https://your-lambda-function-url.lambda-url.ap-southeast-1.on.aws/

# Optional lambda paths (defaults shown)
VITE_COUNTRY_SUMMARY_PATH=/country-summary
VITE_COUNTRY_OVERVIEW_PATH=/country-overview
VITE_COUNTRY_NEWS_PATH=/country-news

# Cloudflare Turnstile site key (frontend)
VITE_TURNSTILE_SITE_KEY=YOUR_SITE_KEY_HERE

# Subscription endpoint (defaults to VITE_COUNTRY_NEWS_LAMBDA_URL + /subscribe)
VITE_SUBSCRIPTION_LAMBDA_URL=
VITE_SUBSCRIPTION_PATH=/subscribe
